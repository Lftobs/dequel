{
  email {$CADDY_EMAIL:admin@dequel.local}
}

import /etc/caddy/routes/*.caddy

:80 {
  log {
    output stdout
    format json
  }

  encode zstd gzip

  handle /api/* {
    reverse_proxy api:3001
  }

  handle /metrics* {
    reverse_proxy prometheus:9090
  }

  redir /grafana /grafana/

  handle /grafana/* {
    reverse_proxy grafana:3000
  }

  handle {
    reverse_proxy web:3000
  }
}

{$CADDY_BASE_DOMAIN:localhost}:443 {
  log {
    output stdout
    format json
  }

  encode zstd gzip

  handle /api/* {
    reverse_proxy api:3001
  }

  handle /metrics* {
    reverse_proxy prometheus:9090
  }

  redir /grafana /grafana/

  handle /grafana/* {
    reverse_proxy grafana:3000
  }

  handle {
    reverse_proxy web:3000
  }
}
