---
import "../styles/global.css";
import { getCollection } from "astro:content";

interface Props {
	title?: string;
	category?: string;
	description?: string;
	currentSlug?: string;
	frontmatter?: {
		title?: string;
		currentSlug?: string;
		category?: string;
		description?: string;
	};
}

const {
	title: directTitle,
	category: directCategory,
	description: directDescription,
	currentSlug: directSlug,
	frontmatter,
} = Astro.props;
const title =
	directTitle || frontmatter?.title || "";
const currentSlug =
	directSlug || frontmatter?.currentSlug || "";
const category =
	directCategory || frontmatter?.category || "";
const description =
	directDescription ||
	frontmatter?.description ||
	"";

const allDocs = await getCollection("docs");
const categoryOrder = [
	"Getting Started",
	"Core Architecture",
	"Cluster Storage & Data",
	"Networking & Security",
	"Release",
];
const grouped: Record<string, { title: string; href: string; slug: string }[]> = {};
for (const entry of allDocs) {
	const cat = entry.data.category;
	if (!grouped[cat]) grouped[cat] = [];
	grouped[cat].push({
		title: entry.data.title,
		href: entry.data.slug === "docs" ? "/docs" : `/docs/${entry.data.slug}`,
		slug: entry.data.slug,
	});
}
const docMenu = categoryOrder
	.filter((cat) => grouped[cat])
	.map((cat) => ({ title: cat, items: grouped[cat] }));
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Dequel Documentation - Learn to deploy, scale, and monitor containers on your cluster."
		/>
		<meta
			name="viewport"
			content="width=device-width"
		/>
		<link
			rel="preconnect"
			href="https://fonts.googleapis.com"
		/>
		<link
			rel="preconnect"
			href="https://fonts.gstatic.com"
			crossorigin
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Play:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&display=swap"
			rel="stylesheet"
		/>
		<link
			rel="icon"
			type="image/svg+xml"
			href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' fill='none'%3E%3ClinearGradient id='g' x1='0' y1='0' x2='32' y2='32' gradientUnits='userSpaceOnUse'%3E%3Cstop offset='0%25' stop-color='%23f59e0b'/%3E%3Cstop offset='50%25' stop-color='%23ea580c'/%3E%3Cstop offset='100%25' stop-color='%23ec4899'/%3E%3C/linearGradient%3E%3Cpath d='M12 8H20C24.4183 8 28 11.5817 28 16C28 20.4183 24.4183 24 20 24H12' stroke='url(%23g)' stroke-width='3' stroke-linecap='round'/%3E%3Cpath d='M20 24H12C7.58172 24 4 20.4183 4 16C4 11.5817 7.58172 8 12 8H16' stroke='url(%23g)' stroke-width='3' stroke-linecap='round' stroke-dasharray='40 10'/%3E%3Ccircle cx='16' cy='16' r='3.5' fill='url(%23g)'/%3E%3C/svg%3E"
		/>
		<meta
			name="generator"
			content={Astro.generator}
		/>
		<title>{title} | Dequel Docs</title>
	</head>
	<body class="min-h-screen dq-noise">
		<div
			class="flex flex-col min-h-screen relative z-10"
		>
			<header class="dq-nav">
				<div class="dq-nav-inner">
					<div
						class="flex items-center gap-6"
					>
						<a
							href="/"
							class="dq-nav-brand"
						>
							<svg
								viewBox="0 0 32 32"
								fill="none"
								xmlns="http://www.w3.org/2000/svg"
								width="24"
								height="24"
							>
								<defs>
									<linearGradient
										id="doc-logo-g"
										x1="0"
										y1="0"
										x2="32"
										y2="32"
										gradientUnits="userSpaceOnUse"
									>
										<stop
											offset="0%"
											stop-color="#f59e0b"
										></stop>
										<stop
											offset="50%"
											stop-color="#ea580c"
										></stop>
										<stop
											offset="100%"
											stop-color="#ec4899"
										></stop>
									</linearGradient>
								</defs>
								<path
									d="M12 8H20C24.4183 8 28 11.5817 28 16C28 20.4183 24.4183 24 20 24H12"
									stroke="url(#doc-logo-g)"
									stroke-width="3.5"
									stroke-linecap="round"
								></path>
								<path
									d="M20 24H12C7.58172 24 4 20.4183 4 16C4 11.5817 7.58172 8 12 8H16"
									stroke="url(#doc-logo-g)"
									stroke-width="3.5"
									stroke-linecap="round"
									stroke-dasharray="40 10"
								></path>
								<circle
									cx="16"
									cy="16"
									r="3.5"
									fill="url(#doc-logo-g)"
								></circle>
							</svg>
							<span
								class="dq-nav-wordmark"
								>dequel</span
							>
							<span
								style="font-size:0.6rem;color:var(--dq-text-faint);text-transform:uppercase;letter-spacing:0.1em;font-weight:700;margin-left:0.25rem;"
								>Docs</span
							>
						</a>
					</div>

					<div
						class="flex items-center gap-4"
					>
						<a
							href="/"
							class="dq-nav-link"
							style="font-size:0.72rem;"
							>Home</a
						>
						<a
							href="/docs/installation"
							class="dq-btn dq-btn--ghost"
							style="font-size:0.68rem;"
						>
							Install <span
								class="dq-btn-arrow"
								>→</span
							>
						</a>

						<button
							id="mobile-menu-toggle"
							class="p-1.5 border border-[var(--dq-border)] text-[var(--dq-text-muted)] hover:text-[var(--dq-text)] md:hidden"
							aria-label="Open menu"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="18"
								height="18"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><line
									x1="3"
									y1="12"
									x2="21"
									y2="12"
								></line><line
									x1="3"
									y1="6"
									x2="21"
									y2="6"
								></line><line
									x1="3"
									y1="18"
									x2="21"
									y2="18"
								></line></svg
							>
						</button>
					</div>
				</div>
			</header>

			<div
				class="flex-1 flex max-w-[1100px] mx-auto w-full px-6"
				style="padding-top:56px;"
			>
				<aside
					class="hidden md:block w-[220px] shrink-0 border-r border-[var(--dq-border-subtle)] pr-4 py-8 sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto"
				>
					<nav class="space-y-6">
						{
							docMenu.map(
								(group) => (
									<div class="space-y-2">
										<h4
											class="text-[10px] uppercase font-bold tracking-[0.12em] pl-2"
											style="color:var(--dq-text-faint);"
										>
											{
												group.title
											}
										</h4>
										<ul class="space-y-0.5">
											{group.items.map(
												(
													item,
												) => {
													const isActive =
														currentSlug ===
															item.slug ||
														(currentSlug ===
															"" &&
															item.slug ===
																"docs");
													return (
														<li>
															<a
																href={
																	item.href
																}
																class={`block text-xs px-2.5 py-2 font-bold transition-all duration-100 border-l-2 ${
																	isActive
																		? "border-[var(--dq-amber)] text-[var(--dq-amber)] bg-[rgba(245,158,11,0.05)]"
																		: "border-transparent text-[var(--dq-text-muted)] hover:text-[var(--dq-text)] hover:border-[var(--dq-border)]"
																}`}
															>
																{
																	item.title
																}
															</a>
														</li>
													);
												},
											)}
										</ul>
									</div>
								),
							)
						}
					</nav>
				</aside>

				<div
					id="mobile-sidebar"
					class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden md:hidden"
				>
					<div
						class="fixed top-0 bottom-0 left-0 w-[260px] bg-[var(--dq-surface)] border-r border-[var(--dq-border)] p-6 overflow-y-auto space-y-6"
					>
						<div
							class="flex items-center justify-between pb-4 border-b border-[var(--dq-border)]"
						>
							<span
								class="font-bold text-sm flex items-center gap-2"
								style="color:var(--dq-text);"
							>
								<svg
									viewBox="0 0 32 32"
									fill="none"
									xmlns="http://www.w3.org/2000/svg"
									width="20"
									height="20"
								>
									<defs>
										<linearGradient
											id="mob-logo-g"
											x1="0"
											y1="0"
											x2="32"
											y2="32"
											gradientUnits="userSpaceOnUse"
										>
											<stop
												offset="0%"
												stop-color="#f59e0b"
											>
											</stop>
											<stop
												offset="50%"
												stop-color="#ea580c"
											>
											</stop>
											<stop
												offset="100%"
												stop-color="#ec4899"
											>
											</stop>
										</linearGradient>
									</defs>
									<path
										d="M12 8H20C24.4183 8 28 11.5817 28 16C28 20.4183 24.4183 24 20 24H12"
										stroke="url(#mob-logo-g)"
										stroke-width="3.5"
										stroke-linecap="round"
									></path>
									<path
										d="M20 24H12C7.58172 24 4 20.4183 4 16C4 11.5817 7.58172 8 12 8H16"
										stroke="url(#mob-logo-g)"
										stroke-width="3.5"
										stroke-linecap="round"
										stroke-dasharray="40 10"
									></path>
									<circle
										cx="16"
										cy="16"
										r="3.5"
										fill="url(#mob-logo-g)"
									></circle>
								</svg>
								Dequel Docs
							</span>
							<button
								id="mobile-menu-close"
								class="p-1 hover:bg-[var(--dq-surface-overlay)]"
								style="color:var(--dq-text-muted);"
								aria-label="Close menu"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									><line
										x1="18"
										y1="6"
										x2="6"
										y2="18"
									></line><line
										x1="6"
										y1="6"
										x2="18"
										y2="18"
									></line></svg
								>
							</button>
						</div>
						<nav class="space-y-6">
							{
								docMenu.map(
									(group) => (
										<div class="space-y-2">
											<h4
												class="text-[10px] uppercase font-bold tracking-[0.12em] pl-2"
												style="color:var(--dq-text-faint);"
											>
												{
													group.title
												}
											</h4>
											<ul class="space-y-0.5">
												{group.items.map(
													(
														item,
													) => {
														const isActive =
															currentSlug ===
																item.slug ||
															(currentSlug ===
																"" &&
																item.slug ===
																	"docs");
														return (
															<li>
																<a
																	href={
																		item.href
																	}
																	class={`block text-xs px-2.5 py-2 font-bold transition-all duration-100 border-l-2 ${
																		isActive
																			? "border-[var(--dq-amber)] text-[var(--dq-amber)]"
																			: "border-transparent text-[var(--dq-text-muted)] hover:text-[var(--dq-text)]"
																	}`}
																>
																	{
																		item.title
																	}
																</a>
															</li>
														);
													},
												)}
											</ul>
										</div>
									),
								)
							}
						</nav>
					</div>
				</div>

				<main
					class="flex-1 min-w-0 md:pl-8 py-8 md:py-10 max-w-[840px]"
				>
					<div
						class="prose prose-invert max-w-none"
					>
						{
							(category ||
								title ||
								description) && (
								<div class="space-y-2 mb-6">
									{category && (
										<div class="text-[10px] font-bold text-primary uppercase tracking-wider">
											{
												category
											}
										</div>
									)}
									{title && (
										<h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-foreground">
											{
												title
											}
										</h1>
									)}
									{description && (
										<p class="text-sm text-zinc-400 max-w-2xl leading-relaxed">
											{
												description
											}
										</p>
									)}
									<hr
										class="border-border/60"
										style="margin-top: 1rem; margin-bottom: 1.5rem;"
									/>
								</div>
							)
						}
						<slot />
					</div>
				</main>
			</div>

			<footer class="dq-footer">
				<div class="dq-footer-inner">
					<p class="dq-footer-copy">
						© {
							new Date().getFullYear()
						} Dequel. Self-hosted container
						platform.
					</p>
				</div>
			</footer>
		</div>

		<script>
			const toggleBtn =
				document.getElementById(
					"mobile-menu-toggle",
				);
			const closeBtn =
				document.getElementById(
					"mobile-menu-close",
				);
			const sidebar =
				document.getElementById(
					"mobile-sidebar",
				);

			toggleBtn?.addEventListener(
				"click",
				() => {
					sidebar?.classList.remove(
						"hidden",
					);
				},
			);

			closeBtn?.addEventListener(
				"click",
				() => {
					sidebar?.classList.add(
						"hidden",
					);
				},
			);

			sidebar?.addEventListener(
				"click",
				(e) => {
					if (e.target === sidebar) {
						sidebar.classList.add(
							"hidden",
						);
					}
				},
			);
		</script>
	</body>
</html>
