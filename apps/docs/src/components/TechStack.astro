---
const techs = ["Docker", "Caddy", "Prometheus", "Grafana", "Loki", "PostgreSQL"];
---

<div class="dq-stack">
  <div class="dq-stack-inner">
    <span class="dq-stack-label">Built on</span>
    <div class="dq-stack-items">
      {techs.map((tech) => (
        <span class="dq-stack-item">{tech}</span>
      ))}
    </div>
  </div>
</div>
