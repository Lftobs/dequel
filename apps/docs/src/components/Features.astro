---
const features = [
  {
    num: "01",
    name: "Instant Deployments",
    desc: "Push code and watch it go live in seconds. Zero-downtime deployments with automatic container rollbacks.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0 0 0 0 0 0 0a2.12 2.12 0 0 1 0-3L12 9"/><path d="M17.64 15 22 10.64"/><path d="m20.91 11.7-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91"/></svg>`
  },
  {
    num: "02",
    name: "Custom Domains & SSL",
    desc: "Automatic HTTPS with Let's Encrypt, custom domain routing, and wildcard certificates via Caddy reverse proxy.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`
  },
  {
    num: "03",
    name: "Observability",
    desc: "Real-time metrics, request monitoring, and log aggregation powered by Prometheus, Loki, and Grafana.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`
  },
  {
    num: "04",
    name: "Managed Databases",
    desc: "One-click PostgreSQL instances with automatic backups, connection pooling, and private network attachment.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>`
  },
  {
    num: "05",
    name: "Auto Scaling",
    desc: "Scale horizontally based on CPU, memory, or request load. Define min/max replicas with zero-config policies.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`
  },
  {
    num: "06",
    name: "Secure by Default",
    desc: "Container isolation, encrypted environment variables, network policies, and audit logging built into every layer.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`
  }
];
---

<section class="dq-features dq-hlines dq-reveal" id="features">
  <div class="dq-features-header">
    <div class="dq-features-eyebrow">Platform Capabilities</div>
    <h2 class="dq-features-title">
      Everything you need to ship.<br/>
      Nothing you don't.
    </h2>
  </div>

  <div class="dq-features-grid">
    {features.map((feature) => (
      <div class="dq-feature-card">
        <div class="dq-feature-num">{feature.num}</div>
        <div class="dq-feature-icon" set:html={feature.iconHtml}></div>
        <h3 class="dq-feature-name">{feature.name}</h3>
        <p class="dq-feature-desc">{feature.desc}</p>
      </div>
    ))}
  </div>
</section>
