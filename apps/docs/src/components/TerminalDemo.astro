---
---

<section class="dq-terminal-section dq-reveal" id="demo">
  <div class="dq-terminal-layout">
    <div class="dq-terminal-text">
      <div class="dq-terminal-text-eyebrow">Developer Experience</div>
      <h2>From git push to production<br/>in under 4 seconds.</h2>
      <p>
        Connect your repository, push to main, and Dequel handles the rest —
        building your container image, routing traffic, provisioning SSL,
        and serving your application at a custom domain.
      </p>
    </div>
    <div class="dq-terminal" id="terminal-demo">
      <div class="dq-terminal-header">
        <div class="dq-terminal-dots">
          <span class="dq-terminal-dot dq-terminal-dot--r"></span>
          <span class="dq-terminal-dot dq-terminal-dot--y"></span>
          <span class="dq-terminal-dot dq-terminal-dot--g"></span>
        </div>
        <span class="dq-terminal-title">dequel — deploy</span>
      </div>
      <div class="dq-terminal-body" id="terminal-output">
        <div><span class="dq-t-prompt">$ </span><span class="dq-t-cmd" id="t-line-0"></span><span class="dq-t-cursor" id="t-cursor"></span></div>
      </div>
    </div>
  </div>
</section>
